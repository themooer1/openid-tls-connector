/target

# Local config and secrets — never commit real credentials.
config.toml
signing_key*.pem
*.pem
*.key

# Python venv used by the conformance suite test orchestrator.
integration_tests/.venv/

# The vendored conformance-suite checkout is cloned by run.sh / the user
# (see integration_tests/README.md) and is not committed to this repo.
integration_tests/conformance-suite/

# Per-run conformance suite export archives.
integration_tests/*.zip
